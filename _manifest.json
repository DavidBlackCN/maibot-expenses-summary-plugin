{
  "manifest_version": 2,
  "id": "davidblackcn.maibot-expenses-summary-plugin",
  "name": "麦麦财务总结插件",
  "version": "1.0.0",
  "description": "统计当天模型调用次数和花费，并以默认或麦晨风模式生成转发消息财报。",
  "author": {
    "name": "DavidBlackCN",
    "url": "https://github.com/DavidBlackCN"
  },
  "license": "MIT",
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "urls": {
    "homepage": "https://github.com/DavidBlackCN/maibot-expenses-summary-plugin",
    "repository": "https://github.com/DavidBlackCN/maibot-expenses-summary-plugin"
  },
  "capabilities": [
    "send.forward",
    "send.text",
    "send.image",
    "send.audio",
    "render.html2png",
    "llm.generate",
    "statistics",
    "statistics.local",
    "statistics.local.models",
    "statistics.local.model_trend",
    "statistics.local.message_trend"
  ],
  "display": {
    "icon": {
      "type": "emoji",
      "value": "💸"
    }
  },
  "i18n": {
    "default_locale": "zh-CN"
  }
}
